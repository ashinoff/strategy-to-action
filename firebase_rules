rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      // Users can read/write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Superadmin (admin_ia) can read ALL users
      allow read: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin_ia';
      
      // Superadmin can write to any user doc (for creating accounts via admin panel)
      allow write: if request.auth != null
        && request.auth.token.email == 'adam-ashinoff@mail.ru';
      
      // Zam RIRU can read users in same enterprise
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'zam_riru'
        && resource.data.enterprise == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.enterprise;
    }
  }
}

